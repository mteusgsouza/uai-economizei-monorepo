{
  "name": "@workspace/database",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "prisma": {
    "schema": "./schema"
  },
  "scripts": {
    "build": "prisma generate && tsc",
    "db:push": "prisma db push",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "import:firebase": "npx tsx scripts/import-firebase.ts",
    "import:firebase:dry": "npx tsx scripts/import-firebase.ts --dry-run",
    "import:firebase:orders-only": "npx tsx scripts/import-firebase.ts --orders-only --delete-orders",
    "import:firebase:orders-only:dry": "npx tsx scripts/import-firebase.ts --orders-only --dry-run"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@prisma/client-runtime-utils": "^7.0.0",
    "dotenv": "^17.4.2",
    "firebase-admin": "^14.1.0",
    "pg": "^8.0.0"
  },
  "devDependencies": {
    "@types/pg": "^8.0.0",
    "@workspace/typescript-config": "workspace:*",
    "prisma": "^7.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
